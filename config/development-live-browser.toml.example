# Stormhelm live browser provider integration profile.
# Copy or pass this file explicitly for local diagnostics only.
# Normal defaults remain disabled and normal CI does not require Obscura or Playwright.

[web_retrieval]
enabled = true

[web_retrieval.obscura]
enabled = true
binary_path = "obscura"
mode = "cli"
allow_cdp_server = false
stealth_enabled = false
allow_js_eval = false

[web_retrieval.obscura.cdp]
enabled = true
binary_path = "obscura"
host = "127.0.0.1"
port = 0
allow_runtime_eval = false
allow_input_domain = false
allow_cookies = false
allow_logged_in_context = false
allow_screenshots = false

[screen_awareness.browser_adapters.playwright]
enabled = true
provider = "playwright"
mode = "semantic_observation"
allow_dev_adapter = true
allow_browser_launch = false
allow_connect_existing = false
allow_actions = false
allow_click = false
allow_focus = false
allow_type_text = false
allow_check = false
allow_uncheck = false
allow_select_option = false
allow_scroll = false
allow_scroll_to_target = false
allow_form_fill = false
allow_form_submit = false
allow_login = false
allow_cookies = false
allow_user_profile = false
allow_payment = false
allow_screenshots = false
allow_dev_actions = false
allow_dev_type_text = false
allow_dev_choice_controls = false
allow_dev_scroll = false
max_scroll_attempts = 5
scroll_step_pixels = 700
scroll_timeout_seconds = 8.0
max_scroll_distance_pixels = 5000
debug_events_enabled = true
