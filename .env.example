## Copy this file to .env for local development.
## Stormhelm loads .env, not .env.example.
STORMHELM_ENV=development
STORMHELM_DEBUG=true
STORMHELM_RELEASE_CHANNEL=dev
STORMHELM_CORE_HOST=127.0.0.1
STORMHELM_CORE_PORT=8765
STORMHELM_DATA_DIR=
STORMHELM_MAX_CONCURRENT_JOBS=8
STORMHELM_DEFAULT_JOB_TIMEOUT_SECONDS=30
STORMHELM_OPENAI_ENABLED=true
STORMHELM_OPENAI_MODEL=gpt-5.4-mini
STORMHELM_OPENAI_TIMEOUT_SECONDS=60
STORMHELM_OPENAI_MAX_TOOL_ROUNDS=4
STORMHELM_OPENAI_MAX_OUTPUT_TOKENS=1200
